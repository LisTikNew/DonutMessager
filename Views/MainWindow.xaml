<Window x:Class="DonutMessager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DonutMessager.Converters"
        xmlns:conv="clr-namespace:DonutMessager.Converters"
        Title="Donut Messenger" 
        MinWidth="900" MinHeight="600"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InverseBooleanToVisibilityConverter x:Key="BoolToVisibilityInverse"/>
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:NotNullToCollapsedConverter x:Key="NotNullToCollapsedConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Gemini_Generated_Image_f0p71df0p71df0p7.png" Stretch="UniformToFill" TileMode="Tile"/>
        </Grid.Background>


        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#CC100F0F" BorderBrush="#333" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="10,10,10,5">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Tag="Поиск по @username..." Height="35" 
                     VerticalContentAlignment="Center" Padding="10,0"
                     Background="#44000000" Foreground="White" BorderBrush="#555"/>

                    <ListBox ItemsSource="{Binding FoundUsers}" 
                     Visibility="{Binding FoundUsers.Count, Converter={StaticResource CountToVisibilityConverter}}"
                     Background="#592D2D2D" MaxHeight="180" Margin="0,5,0,0" 
                     BorderThickness="0" BorderBrush="#FFABADB3">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Cursor="Hand" Background="Transparent">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" 
                                              Command="{Binding DataContext.SelectFoundUserCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                              CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="25" Height="25" Fill="DeepPink" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Username}" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <ListBox Grid.Row="1" ItemsSource="{Binding Chats}" SelectedItem="{Binding SelectedChat}"
                 Background="Transparent" BorderThickness="0" Margin="0,5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="45" Height="45" CornerRadius="22.5" ClipToBounds="True" Margin="0,0,12,0">
                                        <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2" Background="#44000000" Padding="12" BorderThickness="0,1,0,0" BorderBrush="#333">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" CornerRadius="20" ClipToBounds="True" Margin="0,0,10,0">
                                <Image Source="{Binding CurrentUser.AvatarPath}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUser.Name}" Foreground="White" FontWeight="Bold"/>
                                <TextBlock Text="Online" Foreground="#88FFFFFF" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Content="⚙" Width="30" Height="30" 
                        Click="OpenSettings_Click" Background="Transparent" Foreground="White" 
                        BorderThickness="0" Cursor="Hand" FontSize="18"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid Panel.ZIndex="1" Visibility="{Binding SelectedChat, Converter={StaticResource NullToVisibilityConverter}}">
                <Label Content="Pick one to chat with!" 
           Background="#CC000000" 
           Foreground="White" 
           FontSize="24" 
           FontFamily="Arial Black"
           HorizontalContentAlignment="Center" 
           VerticalContentAlignment="Center"
           
           HorizontalAlignment="Stretch" 
           VerticalAlignment="Center" 
           Height="60">
                    <Label.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Label.RenderTransform>
                </Label>
            </Grid>

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="65"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="12" Padding="10" Background="#67000000" BorderThickness="1" BorderBrush="#33FFFFFF">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="40" Height="39" Fill="#555" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedChat.Title}" Foreground="White" FontWeight="Bold" FontSize="17"/>
                            <TextBlock FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Online"/>
                                        <Setter Property="Foreground" Value="#88FFFFFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTyping}" Value="True">
                                                <Setter Property="Text" Value="typing..."/>
                                                <Setter Property="Foreground" Value="Pink"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" x:Name="ChatScroll" VerticalScrollBarVisibility="Auto" Margin="0,10">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left"
                                                Visibility="{Binding IsMine, Converter={StaticResource BoolToVisibilityInverse}}">
                                        <Ellipse Width="32" Height="32" Margin="0,0,8,0" VerticalAlignment="Bottom">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding SenderAvatar, TargetNullValue='/Images/default_avatar.png'}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Border Background="#EEE" CornerRadius="15,15,15,2" Padding="12" MaxWidth="350">
                                            <TextBlock Text="{Binding Text}" Foreground="#222" TextWrapping="Wrap" FontSize="14"/>
                                        </Border>
                                    </StackPanel>

                                    <Border Grid.Column="1" Background="#FF7A2691" CornerRadius="15,15,2,15" 
                                            Padding="12" MaxWidth="350" HorizontalAlignment="Right"
                                            Visibility="{Binding IsMine, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="{Binding Text}" Foreground="White" TextWrapping="Wrap" FontSize="14"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Grid.Row="2" VerticalAlignment="Bottom" Margin="0,0,0,5">
                    <Border Background="#AA000000" CornerRadius="25" BorderBrush="#FFF87DFF" BorderThickness="1.5" Height="50"/>
                    <Grid Margin="20,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" 
         Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
         Foreground="White" Background="Transparent" BorderThickness="0"
         VerticalContentAlignment="Center" FontSize="15" CaretBrush="White">

                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}"/>
                            </TextBox.InputBindings>

                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding SendMessageCommand}" 
                                Width="40" Height="40" Background="{x:Null}" BorderThickness="0" Cursor="Hand">
                            <Image Source="/Views/image-removebg-preview.png" Stretch="Uniform" Opacity="0.9"/>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>