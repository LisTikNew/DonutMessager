<Window x:Class="DonutMessager.Views.CreateUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Account" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        MinWidth="400"
        MaxWidth="450" Height="470">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <LinearGradientBrush.RelativeTransform>
                <TransformGroup>
                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                    <RotateTransform Angle="21.801" CenterX="0.5" CenterY="0.5"/>
                    <TranslateTransform/>
                </TransformGroup>
            </LinearGradientBrush.RelativeTransform>
            <GradientStop Color="Black"/>
            <GradientStop Color="#FF373737" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="246"/>
            <RowDefinition Height="0.56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="179.96"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="0*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Create new account"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,-4,0,4" Width="204"/>

        <!-- Аватар -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,20" Grid.RowSpan="2" Width="150">
            <Border Width="120" Height="120" CornerRadius="60"
                    BorderBrush="#444" BorderThickness="2"
                    Margin="0 10 0 10">
                <Image Source="{Binding AvatarPath}"
                       Stretch="UniformToFill"/>
            </Border>

            <Button Content="Choose avatar"
                    Width="150"
                    Command="{Binding SelectAvatarCommand}"/>
        </StackPanel>

        <StackPanel Margin="20,20,20,4">

            <TextBlock Text="Username" Foreground="White" FontSize="16" Height="35" Padding="0,8,0,0"/>
            <TextBox Text="{Binding Username}" Height="32" Margin="0,5,0,15"/>

            <TextBlock Text="Password" Foreground="White" FontSize="16" Height="30"/>
            <PasswordBox x:Name="PasswordBox"
                 Height="32"
                 Margin="0,5,0,15"
                 PasswordChanged="PasswordBox_OnPasswordChanged"/>
            <Button Content="Create Account"
            Command="{Binding CreateUserCommand}"
            Height="55"
            FontSize="18"/>
        </StackPanel>
    </Grid>
</Window>