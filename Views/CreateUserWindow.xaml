<Window x:Class="DonutMessager.Views.CreateUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create User" Height="300" Width="300">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FFC7F1FF"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <StackPanel Margin="20">

        <TextBlock Text="Enter name:" FontSize="16"/>
        <TextBox Text="{Binding Username}" Margin="0,5,0,10"/>

        <TextBlock Text="Choose avatar:" FontSize="16"/>
        <Button Content="Select image" Command="{Binding SelectAvatarCommand}" Margin="0,5,0,10"/>

        <Image Source="{Binding AvatarPath, TargetNullValue=/Images/default_avatar.png}" Height="80" Margin="0,5,0,10"/>

        <Button Content="Create" Command="{Binding CreateCommand}" Width="100" HorizontalAlignment="Center"/>

    </StackPanel>
</Window>