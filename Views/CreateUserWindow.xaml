<Window x:Class="DonutMessager.Views.CreateUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Account" Height="400" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <LinearGradientBrush.RelativeTransform>
                <TransformGroup>
                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                    <RotateTransform Angle="21.801" CenterX="0.5" CenterY="0.5"/>
                    <TranslateTransform/>
                </TransformGroup>
            </LinearGradientBrush.RelativeTransform>
            <GradientStop Color="Black"/>
            <GradientStop Color="#FF373737" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Create new account"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <!-- Аватар -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
            <Border Width="120" Height="120" CornerRadius="60"
                    BorderBrush="#444" BorderThickness="2"
                    Margin="0 10 0 10">
                <Image Source="{Binding AvatarPath}"
                       Stretch="UniformToFill"/>
            </Border>

            <Button Content="Choose avatar"
                    Width="150"
                    Command="{Binding SelectAvatarCommand}"/>
        </StackPanel>

        <!-- Имя пользователя -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Username"
                       Foreground="White"
                       Margin="0 0 0 5"/>
            <TextBox Text="{Binding Username}"
                     Height="30"
                     FontSize="16"/>
        </StackPanel>

        <!-- Кнопка создания -->
        <Button Grid.Row="5"
                Content="Create account"
                Height="40"
                Margin="0 20 0 0"
                Command="{Binding CreateUserCommand}"/>
    </Grid>
</Window>