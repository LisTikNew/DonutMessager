<Window x:Class="DonutMessager.Views.ConfirmLogoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="220"
        Height="120"
        Background="#FF2A2A2A"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        Opacity="0.95"
        ShowInTaskbar="False"
        Topmost="True">

    <Border CornerRadius="10" Background="#FF2A2A2A" Padding="15">
        <StackPanel>

            <TextBlock Text="Logout?"
                       Foreground="White"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 10"/>

            <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,0,0,0">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Margin" Value="5,0"/>
                    </Style>
                </StackPanel.Resources>

                <Button Content="Yes"
                        Width="70"
                        Height="28"
                        Background="#FFB00020"
                        Foreground="White"
                        Click="Yes_Click"/>

                <Button Content="No"
                        Width="70"
                        Height="28"
                        Background="#FF444444"
                        Foreground="White"
                        Click="No_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>