<Application x:Class="DonutMessager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:DonutMessager.Converters">

    <Application.Resources>
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <conv:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:NotNullToCollapsedConverter x:Key="NotNullToCollapsedConverter"/>
    </Application.Resources>

</Application>